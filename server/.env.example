# NexusResearch 后端环境变量示例。复制为 .env 并按需修改。
# 所有变量前缀 NEXUS_。详见 app/core/config.py。

# 运行环境：development | production
NEXUS_ENV=development

# 监听（开发期固定；打包后由 Electron 注入）
NEXUS_HOST=127.0.0.1
NEXUS_PORT=8000

# 用户数据目录（留空则用平台默认：APPDATA/Library/~.local/share）
# 开发期设为 1 则回落到 server/.data，便于隔离测试
NEXUS_DEV=1

# API Key 加密主密钥（生产期必须显式注入，留空则开发期用占位符）
NEXUS_SECRET_KEY=
