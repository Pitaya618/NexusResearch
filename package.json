{
  "name": "nexus-research",
  "private": true,
  "version": "0.1.0",
  "description": "NexusResearch — AI 科研助手（前端 + Electron 桌面壳 monorepo 根）",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "electron-builder"]
  },
  "scripts": {
    "dev": "pnpm --filter @nexus/web dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "codegen": "pnpm --filter @nexus/codegen run gen",
    "codegen:schema": "pnpm --filter @nexus/codegen run schema",
    "codegen:py": "pnpm --filter @nexus/codegen run py",
    "dev:server": "cd server && set NEXUS_DEV=1 && .venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --port 8000"
  },
  "packageManager": "pnpm@10.32.1"
}
